# 复制为 .env.deploy 并填入实际值（.env.deploy 已加入 .gitignore）

# ========== GitHub Actions 部署 (Vercel) ==========
# 将以下值添加到 GitHub: Settings → Secrets → Actions
# VERCEL_TOKEN      = https://vercel.com/account/tokens 创建
# VERCEL_ORG_ID     = 运行 node scripts/get-vercel-ids.js 获取
# VERCEL_PROJECT_ID = 同上

# ========== Namecheap DNS 自动化 ==========
# 运行 node scripts/setup-namecheap-dns.js 前设置
NC_API_USER=你的ApiUser
NC_API_KEY=你的ApiKey
NC_USERNAME=你的Namecheap用户名
NC_CLIENT_IP=已白名单的IP
